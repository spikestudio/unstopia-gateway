{
  "name": "jinn",
  "private": true,
  "packageManager": "pnpm@10.6.4",
  "scripts": {
    "build": "turbo build && rm -rf packages/jimmy/dist/web && cp -r packages/web/out packages/jimmy/dist/web",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo run test",
    "test:e2e": "playwright test",
    "clean": "rm -rf .turbo node_modules/.cache && turbo clean",
    "jinn": "node packages/jimmy/dist/bin/jimmy.js",
    "setup": "pnpm build && node packages/jimmy/dist/bin/jimmy.js setup",
    "setup:force": "pnpm build && node packages/jimmy/dist/bin/jimmy.js setup --force",
    "start": "pnpm clean && pnpm build && node packages/jimmy/dist/bin/jimmy.js start",
    "stop": "node packages/jimmy/dist/bin/jimmy.js stop",
    "nuke": "node packages/jimmy/dist/bin/jimmy.js nuke",
    "status": "node packages/jimmy/dist/bin/jimmy.js status"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "classic-level"
    ],
    "overrides": {
      "axios": ">=1.15.2",
      "follow-redirects": ">=1.16.0",
      "path-to-regexp": ">=8.4.0",
      "lodash": ">=4.18.0",
      "undici": ">=6.24.0",
      "picomatch": ">=4.0.4",
      "vite": ">=8.0.5",
      "next": "^15.5.15",
      "request>form-data": "^2.5.4",
      "request>qs": "^6.14.1",
      "@whiskeysockets/baileys>protobufjs": ">=7.5.5"
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@playwright/test": "^1.58.2",
    "turbo": "^2.4.0",
    "typescript": "^5.8.0"
  },
  "dependencies": {
    "classic-level": "^2.0.0"
  }
}
