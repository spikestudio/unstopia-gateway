# unstopia-gateway 環境変数
# このファイルを .env にコピーして実際の値を設定する

# Gateway 設定
JINN_HOME=~/.jinn                  # Gateway ホームディレクトリ
JINN_PORT=3000                     # Gateway ポート番号
JINN_GATEWAY_URL=http://localhost:3000  # Gateway URL（Connector から参照）

# AI エンジン
GEMINI_API_KEY=                    # Gemini API キー（gemini エンジン使用時）

# 開発用
# JINN_INSTANCE=                   # 複数インスタンス起動時の識別子
